# --- NVIDIA NIM (OpenAI-compatible) ---
# 與 nvidia-tg-bot 同一組設定
NVIDIA_API_KEY=your_nvidia_api_key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# --- FinMind ---
# 免註冊也能用但流量低；註冊後填 token 提高額度: https://finmindtrade.com/
FINMIND_TOKEN=

# --- 篩選參數（可選，留空用預設）---
# 漲幅排行取前幾名
TOP_N=200
# 均線天數（逗號分隔）
MA_WINDOWS=20,60,120,240

# --- LINE 推播設定 ---
LINE_CHANNEL_ACCESS_TOKEN=your_line_bot_token
# 若網址外流，可填入允許接收的 User ID (用半形逗號分隔)，改走 Multicast 指定發送
LINE_ALLOWED_USER_IDS=U1234...,U5678...
